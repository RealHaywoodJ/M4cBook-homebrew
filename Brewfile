# Brewfile for M4 MacBook Setup
# This file defines all the packages and applications to be installed via Homebrew

# Update Homebrew and upgrade any already-installed formulae
tap "homebrew/bundle"

# CLI Tools
brew "gh"  # GitHub CLI

# Applications via Homebrew Cask
cask "postman"
cask "replit"
cask "warp"
cask "visual-studio-code"
cask "github"